{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [2, "always", [
      "feat",    "fix",   "chore",  "docs",
      "style",   "refactor", "test", "ci",
      "perf",    "revert", "build"
    ]],
    "scope-enum": [1, "always", [
      "api", "web", "shared", "ui",
      "auth", "ledger", "programs", "contributions",
      "distribution", "beneficiaries", "vendors",
      "reports", "infra", "ci"
    ]],
    "subject-case": [2, "always", "sentence-case"]
  }
}
