# ── .env.production.example ──────────────────────────────────
# Copy to secrets manager. NEVER commit real values.
# Every variable listed here is REQUIRED in production.
# The API refuses to start if any are missing (see config/env.ts).
 
NODE_ENV=production
PORT=4000
 
# Database — use managed PostgreSQL (e.g. RDS, Railway, Supabase)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/aidflow_prod?sslmode=require
 
# Redis — use managed Redis (e.g. Upstash, ElastiCache, Railway)
REDIS_URL=redis://default:PASSWORD@HOST:6379
 
# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use DIFFERENT keys for access and refresh. Rotate these on security incidents.
JWT_ACCESS_SECRET=REPLACE_64_CHAR_HEX
JWT_REFRESH_SECRET=REPLACE_DIFFERENT_64_CHAR_HEX
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
 
# PII Encryption — 32 bytes (64 hex chars). Losing this key = losing all beneficiary PII.
# Store in a hardware security module (HSM) or secrets manager with backup.
ENCRYPTION_KEY=REPLACE_64_CHAR_HEX
 
# CORS — comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=https://app.aidflow.org,https://aidflow.org
 
# Logging
LOG_LEVEL=info
LOG_FORMAT=json
 
# Feature flags — all off until explicitly enabled
ENABLE_BLOCKCHAIN_SYNC=false
ENABLE_PAYMENT_GATEWAY=false
ENABLE_BIOMETRIC_VERIFICATION=false
 
# Optional: Sentry DSN for error tracking
SENTRY_DSN=
 
# Optional: SMTP for email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@aidflow.org
