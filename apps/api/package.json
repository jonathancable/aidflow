{
  "name": "@aidflow/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev":       "tsx watch src/index.ts",
    "build":     "tsc --project tsconfig.json",
    "start":     "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint":      "eslint src",
    "test":      "vitest run",
    "test:watch":"vitest"
  },
  "dependencies": {
    "@aidflow/shared":  "workspace:*",
    "express":          "^4.19.0",
    "@types/express":   "^4.17.0",
    "prisma":           "^5.14.0",
    "@prisma/client":   "^5.14.0",
    "zod":              "^3.23.0",
    "jsonwebtoken":     "^9.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "bcryptjs":         "^2.4.3",
    "@types/bcryptjs":  "^2.4.0",
    "helmet":           "^7.1.0",
    "cors":             "^2.8.5",
    "@types/cors":      "^2.8.0",
    "express-rate-limit":"^7.3.0",
    "bullmq":           "^5.8.0",
    "ioredis":          "^5.3.0",
    "winston":          "^3.13.0",
    "dotenv":           "^16.4.0"
  },
  "devDependencies": {
    "tsx":     "^4.11.0",
    "vitest":  "^1.6.0"
  }
}