{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@/*":             ["src/*"],
      "@dal/*":          ["src/dal/*"],
      "@services/*":     ["src/services/*"],
      "@routes/*":       ["src/routes/*"],
      "@middleware/*":   ["src/middleware/*"],
      "@config/*":       ["src/config/*"],
      "@types/*":        ["src/types/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}