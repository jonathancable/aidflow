# Copy to .env.local and fill in values
# Never commit .env.local

NODE_ENV=development
PORT=4000

# Database (matches docker-compose)
DATABASE_URL=postgresql://aidflow:aidflow_dev@localhost:5432/aidflow

# Redis (matches docker-compose)
REDIS_URL=redis://localhost:6379

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_HEX
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# PII Encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX_64_CHARS

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173

# Feature flags
ENABLE_BLOCKCHAIN_SYNC=false
ENABLE_PAYMENT_GATEWAY=false
