{
  "permissions": {
    "allow": [
      "Bash(gh repo:*)",
      "Bash(gh --version)",
      "Bash(gh auth:*)",
      "Bash(curl -s -w \" HTTP:%{http_code}\" http://localhost:4000/api/v1/auth/register)",
      "Bash(curl -s -w \" HTTP:%{http_code}\" -X POST http://localhost:4000/api/v1/auth/register)",
      "Bash(pnpm typecheck:*)",
      "Bash(docker exec:*)",
      "Bash(docker compose:*)",
      "Bash(curl -s http://localhost:4000/health)",
      "Bash(docker volume:*)",
      "Bash(pnpm --filter @aidflow/api add -D supertest @types/supertest)",
      "Bash(pnpm vitest:*)"
    ]
  }
}
